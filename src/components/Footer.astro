---
import BrandMark from './BrandMark.astro';

interface Props {
  isAuthenticated?: boolean;
}

const { isAuthenticated = false } = Astro.props;
---

<footer class="border-t border-white/10 bg-[#090d14]">
  <div class="mx-auto max-w-7xl px-6 py-14">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr]">
      <div class="max-w-sm">
        <div class="flex items-center gap-2">
          <BrandMark class="h-10 w-9 object-contain" alt="" />
          <span class="font-display text-lg font-bold tracking-[-0.035em] text-white">TailCache</span>
        </div>
        <p class="mt-4 text-sm text-zinc-400">
          One organized record for every asset, version, creator, license, and backup.
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold tracking-normal text-white">{isAuthenticated ? 'Workspace' : 'Product'}</h3>
        <ul class="mt-4 space-y-3">
          <li><a href={isAuthenticated ? '/library' : '/#features'} class="text-sm text-zinc-400 hover:text-white">{isAuthenticated ? 'Library' : 'Features'}</a></li>
          <li><a href={isAuthenticated ? '/sync' : '/#workflow'} class="text-sm text-zinc-400 hover:text-white">{isAuthenticated ? 'Sync & backups' : 'Workflow'}</a></li>
          <li><a href="/gallery" class="text-sm text-zinc-400 hover:text-white">Gallery</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold tracking-normal text-white">Resources</h3>
        <ul class="mt-4 space-y-3">
          <li><a href="/docs" class="text-sm text-zinc-400 hover:text-white">Docs</a></li>
          <li><a href="/api-docs" class="text-sm text-zinc-400 hover:text-white">API Reference</a></li>
          <li><a href={isAuthenticated ? '/dashboard' : '/login'} class="text-sm text-zinc-400 hover:text-white">{isAuthenticated ? 'Account' : 'Sign in'}</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t border-white/10 pt-7 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-zinc-500">
        TailCache - A Product of CyberFurz LLC
      </p>
      <p class="font-mono text-xs text-zinc-600">Collected · protected · within reach</p>
    </div>
  </div>
</footer>
