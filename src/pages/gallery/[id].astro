---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MarkdownContent from '../../components/MarkdownContent.astro';
import { GalleryPurchaseLinks } from '../../components/GalleryPurchaseLinks';
import { OwnershipClaimForm } from '../../components/OwnershipClaimForm';
import { getSessionFromContext } from '../../lib/session';
import { getVideoEmbedUrl, isDirectVideoUrl } from '../../lib/gallery-media';
import { db } from '../../db';
import {
  products,
  productVersions,
  galleryPurchaseLinks,
  galleryListingMedia,
  marketplaceSources,
  creators,
  fileThumbnails,
  ownershipVerifications,
} from '../../db/schema';
import { and, eq, inArray } from 'drizzle-orm';

const session = await getSessionFromContext(Astro);
const isAuthenticated = !!session?.user;
const productId = Astro.params.id;
if (!productId) return Astro.redirect('/gallery');

const listing = await db.query.products.findFirst({
  where: and(eq(products.id, productId), eq(products.isGalleryListed, true)),
});
if (!listing) return Astro.redirect('/gallery');

const thumbnail = listing.thumbnailFileThumbnailId
  ? await db.query.fileThumbnails.findFirst({ where: eq(fileThumbnails.id, listing.thumbnailFileThumbnailId) })
  : null;
const thumbnailUrl = thumbnail ? `/api/thumbnail/${thumbnail.id}` : null;
const productCreators = listing.creatorIds?.length
  ? await db.query.creators.findMany({ where: inArray(creators.id, listing.creatorIds) })
  : [];
const links = await db.query.galleryPurchaseLinks.findMany({
  where: eq(galleryPurchaseLinks.productId, productId),
  orderBy: (table, { asc }) => [asc(table.sortOrder)],
});
const media = await db.query.galleryListingMedia.findMany({
  where: eq(galleryListingMedia.productId, productId),
  orderBy: (table, { asc }) => [asc(table.sortOrder)],
});
const marketplaceIds = [...new Set(links.map((link) => link.marketplaceSourceId))];
const markets = marketplaceIds.length
  ? await db.query.marketplaceSources.findMany({ where: inArray(marketplaceSources.id, marketplaceIds) })
  : [];
const marketplaceMap = Object.fromEntries(markets.map((marketplace) => [marketplace.id, marketplace]));
const versions = await db.query.productVersions.findMany({
  where: eq(productVersions.productId, productId),
  orderBy: [productVersions.createdAt],
});

let alreadyOwned = false;
let linkedProductId: string | null = null;
if (session?.user) {
  const linked = await db.query.products.findFirst({
    where: and(eq(products.ownerUserId, session.user.id), eq(products.sourceProductId, productId)),
    columns: { id: true },
  });
  if (linked) {
    alreadyOwned = true;
    linkedProductId = linked.id;
  } else {
    const verified = await db.query.ownershipVerifications.findFirst({
      where: and(
        eq(ownershipVerifications.userId, session.user.id),
        eq(ownershipVerifications.productId, productId),
        eq(ownershipVerifications.status, 'verified'),
      ),
    });
    if (verified?.linkedProductId) {
      alreadyOwned = true;
      linkedProductId = verified.linkedProductId;
    }
  }
}

const purchaseLinks = links.map((link) => ({
  id: link.id,
  productUrl: link.productUrl,
  label: link.label,
  marketplace: marketplaceMap[link.marketplaceSourceId]
    ? {
        id: marketplaceMap[link.marketplaceSourceId].id,
        name: marketplaceMap[link.marketplaceSourceId].name,
        slug: marketplaceMap[link.marketplaceSourceId].slug,
      }
    : null,
}));
---

<BaseLayout title={`${listing.title} - Gallery - TailCache`} isAuthenticated={isAuthenticated}>
  <div class="mx-auto max-w-[86rem] px-5 py-8 sm:px-6 sm:py-12">
    <nav aria-label="Breadcrumb" class="mb-7 flex flex-wrap items-center gap-2 text-xs text-zinc-500">
      <a href="/gallery" class="transition-colors hover:text-white">Gallery</a>
      <span aria-hidden="true">/</span>
      {productCreators[0]?.enrolledByUserId ? (
        <a href={`/creators/${productCreators[0].slug}`} class="transition-colors hover:text-white">{productCreators[0].name}</a>
      ) : (
        <span>{productCreators[0]?.name ?? 'Creator'}</span>
      )}
      <span aria-hidden="true">/</span>
      <span class="text-zinc-300">{listing.title}</span>
    </nav>

    <div class="grid items-start gap-8 lg:grid-cols-[minmax(0,1fr)_22rem] xl:gap-12">
      <main class="min-w-0">
        <section aria-label="Product media" class="space-y-4">
          {media.length > 0 ? (
            media.map((item, index) => {
              const embedUrl = item.mediaType === 'video' ? getVideoEmbedUrl(item.url) : null;
              const directVideo = item.mediaType === 'video' && isDirectVideoUrl(item.url);
              return (
                <figure class="overflow-hidden rounded-2xl border border-white/10 bg-[#0d121c] shadow-[0_24px_70px_rgba(0,0,0,0.22)]">
                  {item.mediaType === 'image' ? (
                    <img src={item.url} alt={item.altText || item.caption || `${listing.title} gallery image ${index + 1}`} loading={index === 0 ? 'eager' : 'lazy'} class="h-auto max-h-[78vh] w-full object-contain" />
                  ) : embedUrl ? (
                    <div class="aspect-video">
                      <iframe src={embedUrl} title={item.caption || `${listing.title} video ${index + 1}`} class="h-full w-full" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                    </div>
                  ) : directVideo ? (
                    <video src={item.url} controls preload="metadata" class="aspect-video w-full bg-black">Your browser does not support this video.</video>
                  ) : (
                    <div class="flex aspect-video items-center justify-center p-8 text-center">
                      <a href={item.url} target="_blank" rel="noreferrer" class="btn-secondary">Open video <span aria-hidden="true">↗</span></a>
                    </div>
                  )}
                  {item.caption && <figcaption class="border-t border-white/10 px-4 py-3 text-xs text-zinc-500">{item.caption}</figcaption>}
                </figure>
              );
            })
          ) : (
            <div class="flex aspect-[16/10] items-center justify-center overflow-hidden rounded-2xl border border-white/10 bg-[#0d121c]">
              {thumbnailUrl ? (
                <img src={thumbnailUrl} alt={listing.title} class="h-full w-full object-contain" />
              ) : (
                <div class="flex flex-col items-center gap-3 text-zinc-700">
                  <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.6-4.6a2 2 0 0 1 2.8 0L16 16m-2-2 1.6-1.6a2 2 0 0 1 2.8 0L20 14M6 20h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2Z" /></svg>
                  <span class="text-sm">No gallery media yet</span>
                </div>
              )}
            </div>
          )}
        </section>

        {(listing.descriptionText || versions.length > 0) && (
          <div class="mt-10 grid gap-6 xl:grid-cols-[minmax(0,1fr)_18rem]">
            {listing.descriptionText && (
              <section class="app-panel p-5 sm:p-7" aria-labelledby="about-product">
                <p class="app-kicker">About this product</p>
                <h2 id="about-product" class="mt-2 font-display text-2xl font-semibold text-white">Details</h2>
                <MarkdownContent content={listing.descriptionText} class="mt-5 !text-base !leading-7" />
              </section>
            )}
            {versions.length > 0 && (
              <section class="app-panel p-5" aria-labelledby="version-history">
                <h2 id="version-history" class="font-display text-lg font-semibold text-white">Version history</h2>
                <ul class="mt-4 space-y-3">
                  {[...versions].reverse().map((version) => (
                    <li class="border-l border-indigo-400/30 pl-3">
                      <p class="font-mono text-xs font-medium text-indigo-300">v{version.version}</p>
                      {version.releaseNotes && <p class="mt-1 text-xs leading-5 text-zinc-500">{version.releaseNotes}</p>}
                    </li>
                  ))}
                </ul>
              </section>
            )}
          </div>
        )}

        <div class="mt-6">
          <OwnershipClaimForm
            client:load
            listingId={productId}
            purchaseLinks={purchaseLinks}
            alreadyOwned={alreadyOwned}
            linkedProductId={linkedProductId}
            isAuthenticated={isAuthenticated}
          />
        </div>
      </main>

      <aside class="min-w-0 lg:sticky lg:top-24">
        <div class="app-panel-raised overflow-hidden">
          {thumbnailUrl && (
            <div class="aspect-[16/9] overflow-hidden border-b border-white/10 bg-[#0d121c] lg:aspect-[4/3]">
              <img src={thumbnailUrl} alt="" class="h-full w-full object-cover" />
            </div>
          )}
          <div class="p-5 sm:p-6">
            <p class="app-kicker !text-cyan-300">Creator storefront</p>
            <h1 class="mt-3 font-display text-3xl font-bold leading-tight text-white">{listing.title}</h1>
            {productCreators.length > 0 && (
              <p class="mt-3 text-sm text-zinc-400">
                by{' '}
                {productCreators.map((creator, index) => (
                  <>
                    {index > 0 && ', '}
                    {creator.enrolledByUserId ? (
                      <a href={`/creators/${creator.slug}`} class="font-medium text-zinc-200 underline decoration-white/20 underline-offset-4 transition-colors hover:text-indigo-300">{creator.name}</a>
                    ) : (
                      <span class="font-medium text-zinc-200">{creator.name}</span>
                    )}
                  </>
                ))}
              </p>
            )}

            {listing.tags?.length ? (
              <div class="mt-4 flex flex-wrap gap-1.5">
                {listing.tags.map((tag) => <span class="tag-chip">{tag}</span>)}
              </div>
            ) : null}

            <div class="my-6 h-px bg-white/10"></div>
            <GalleryPurchaseLinks client:load listingId={productId} purchaseLinks={purchaseLinks} />
            <p class="mt-5 font-mono text-[0.62rem] uppercase tracking-[0.12em] text-zinc-600">Updated {new Date(listing.updatedAt).toLocaleDateString()}</p>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
