---
interface Props {
  current: 'dashboard' | 'users' | 'storage' | 'creator-applications' | 'feedback';
}

const { current } = Astro.props;

const links = [
  { key: 'dashboard', label: 'Overview', href: '/admin' },
  { key: 'users', label: 'Users', href: '/admin/users' },
  { key: 'creator-applications', label: 'Creator applications', href: '/admin/creator-applications' },
  { key: 'feedback', label: 'Beta feedback', href: '/admin/feedback' },
  { key: 'storage', label: 'Storage', href: '/admin/storage' },
] as const;
---

<nav aria-label="Admin navigation" class="app-nav">
  {links.map((link) => (
    <a href={link.href} class="app-nav-link" aria-current={current === link.key ? 'page' : undefined}>
      {link.label}
    </a>
  ))}
</nav>
