DATABASE_URL=postgresql://postgres:password@localhost:5432/pdam
BETTER_AUTH_URL=http://localhost:4321
BETTER_AUTH_SECRET=generate_with_openssl_rand_-base64_32
# Google OAuth web-client credentials. The redirect URI is
# http://localhost:4321/api/auth/callback/google in local development.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
SYNC_WORKER_SECRET=generate_with_openssl_rand_-base64_32
# Number of destination sync jobs processed concurrently by the pg-boss worker
SYNC_WORKER_CONCURRENCY=2
WEBHOOK_SECRET_ENCRYPTION_KEY=generate_with_openssl_rand_-hex_32_bytes
# Set true only when the app runs behind a trusted reverse proxy.
# TRUST_PROXY=false

# Storage - set S3_ENDPOINT to enable S3, otherwise defaults to local filesystem
# S3_ENDPOINT=https://s3.us-east-1.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=pdam-assets
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_FORCE_PATH_STYLE=true
# S3_PUBLIC_URL=https://assets.example.com

# Local storage fallback (used when S3_ENDPOINT is not set)
UPLOADS_DIR=./uploads

# Upload limits (optional)
# MAX_UPLOAD_BYTES=53687091200
# MPU_PART_SIZE=67108864
# MPU_PRESIGN_TTL_SECONDS=3600
# MPU_SESSION_TTL_HOURS=48

# Comma-separated emails that are treated as administrators (bootstrap before role is set in DB)
# ADMIN_EMAILS=admin@example.com
