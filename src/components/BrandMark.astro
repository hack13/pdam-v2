---
import logo from '../assets/brand/tailcache-crystal-tail-clean.webp';

interface Props {
  class?: string;
  alt?: string;
}

const { class: className = "", alt = "TailCache crystal-tail mark" } =
  Astro.props;
---

<img
  src={logo.src}
  alt={alt}
  class={className}
  width="1191"
  height="1320"
  decoding="async"
/>
