---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSessionFromContext } from '../lib/session';

const session = await getSessionFromContext(Astro);
const isAuthenticated = !!session?.user;
const guides = [
  {
    href: '/docs/library',
    number: '01',
    title: 'Library',
    subtitle: 'Add and version assets',
    description: 'Build a dependable record for every asset, its creators, license, and release files.',
    accent: 'indigo',
  },
  {
    href: '/docs/creator',
    number: '02',
    title: 'Creator',
    subtitle: 'Claim and publish',
    description: 'Claim your catalog identity, list products, and configure ownership verification.',
    accent: 'violet',
  },
  {
    href: '/docs/sync',
    number: '03',
    title: 'Sync',
    subtitle: 'Connect a backup',
    description: 'Keep independent copies in S3-compatible storage, WebDAV, or Google Drive.',
    accent: 'cyan',
  },
];
---

<BaseLayout title="Docs - TailCache" isAuthenticated={isAuthenticated}>
  <div class="app-page">
    <section class="relative overflow-hidden rounded-3xl border border-indigo-400/15 bg-[#101722] px-6 py-10 sm:px-10 sm:py-14">
      <div class="pointer-events-none absolute inset-0 opacity-70" aria-hidden="true">
        <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full border border-indigo-400/15"></div>
        <div class="absolute -right-8 -top-8 h-40 w-40 rounded-full border border-cyan-400/15"></div>
      </div>
      <div class="relative max-w-3xl">
        <p class="app-kicker">TailCache field guide</p>
        <h1 class="mt-3 font-display text-4xl font-bold tracking-[-0.055em] text-white sm:text-5xl">Find the guide for the job at hand.</h1>
        <p class="mt-5 max-w-2xl text-base leading-7 text-zinc-300">
          Each topic has its own page so it can grow with step-by-step detail, screenshots, and troubleshooting notes.
        </p>
      </div>
    </section>

    <nav aria-label="Documentation guides" class="mt-8 grid gap-4 lg:grid-cols-3">
      {guides.map((guide) => (
        <a
          href={guide.href}
          class:list={[
            'app-panel group relative overflow-hidden p-6 transition-all hover:-translate-y-0.5',
            guide.accent === 'indigo' && 'hover:border-indigo-400/35',
            guide.accent === 'violet' && 'hover:border-violet-400/35',
            guide.accent === 'cyan' && 'hover:border-cyan-400/35',
          ]}
        >
          <div class:list={[
            'absolute inset-y-0 left-0 w-px',
            guide.accent === 'indigo' && 'bg-indigo-400/70',
            guide.accent === 'violet' && 'bg-violet-400/70',
            guide.accent === 'cyan' && 'bg-cyan-400/70',
          ]}></div>
          <p class:list={[
            'font-mono text-xs uppercase tracking-[0.16em]',
            guide.accent === 'indigo' && 'text-indigo-300',
            guide.accent === 'violet' && 'text-violet-300',
            guide.accent === 'cyan' && 'text-cyan-300',
          ]}>{guide.number} · {guide.title}</p>
          <h2 class="mt-3 text-xl font-semibold text-white">{guide.subtitle}</h2>
          <p class="mt-2 text-sm leading-6 text-zinc-400">{guide.description}</p>
          <span class:list={[
            'mt-6 inline-flex items-center gap-2 text-sm font-medium',
            guide.accent === 'indigo' && 'text-indigo-300',
            guide.accent === 'violet' && 'text-violet-300',
            guide.accent === 'cyan' && 'text-cyan-300',
          ]}>Open guide <span class="transition-transform group-hover:translate-x-1" aria-hidden="true">→</span></span>
        </a>
      ))}
    </nav>
  </div>
</BaseLayout>
