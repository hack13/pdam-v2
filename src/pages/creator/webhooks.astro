---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CreatorNav from '../../components/CreatorNav.astro';
import { WebhookManager } from '../../components/WebhookManager';
import { getCreatorUserFromContext } from '../../lib/creator';

const creator = await getCreatorUserFromContext(Astro);
if (!creator) {
  return Astro.redirect('/dashboard');
}
---

<BaseLayout title="Creator Verification - TailCache" isAuthenticated={true}>
  <div class="app-page">
    <div class="app-header">
      <div>
      <p class="app-kicker">Creator studio</p>
      <h1 class="app-title">Verification</h1>
      <p class="app-description">
        Connect the endpoints that confirm ownership for Gumroad, Jinxxy, and other marketplaces.
      </p>
      </div>
    </div>

    <CreatorNav current="webhooks" />

    <WebhookManager client:load />
  </div>
</BaseLayout>
