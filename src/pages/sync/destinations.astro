---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyncNav from '../../components/SyncNav.astro';
import { BackupSyncManager } from '../../components/BackupSyncManager';
import { getSessionFromContext } from '../../lib/session';
const session = await getSessionFromContext(Astro);
if (!session?.user) return Astro.redirect('/login');
---

<BaseLayout title="Sync Destinations - TailCache" isAuthenticated={true}>
  <div class="app-page">
    <div class="app-header"><div><p class="app-kicker">Sync infrastructure</p><h1 class="app-title">Destinations</h1><p class="app-description">Connect storage you control and create narrowly scoped tokens for your own machines.</p></div></div>
    <SyncNav current="destinations" />
    <div class="app-panel-raised p-5 sm:p-6"><BackupSyncManager client:load /></div>
  </div>
</BaseLayout>
