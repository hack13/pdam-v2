---
interface Props {
  current: 'dashboard' | 'destinations' | 'status' | 'client' | 'python';
}
const { current } = Astro.props;
const links = [
  { key: 'dashboard', label: 'Overview', href: '/sync' },
  { key: 'destinations', label: 'Destinations', href: '/sync/destinations' },
  { key: 'status', label: 'Activity', href: '/sync/status' },
  { key: 'python', label: 'Python Sync', href: '/sync/python' },
  { key: 'client', label: 'Local Client', href: '/sync/client' },
] as const;
---

<nav aria-label="Sync navigation" class="mb-8 flex flex-wrap items-center gap-2 border-b border-white/10 pb-3">
  {links.map((link) => (
    <a
      href={link.href}
      class:list={[
        'rounded-lg px-3 py-2 text-sm transition-colors',
        current === link.key
          ? 'bg-indigo-500/15 text-indigo-200 ring-1 ring-inset ring-indigo-400/20'
          : 'text-zinc-400 hover:bg-white/5 hover:text-white',
      ]}
      aria-current={current === link.key ? 'page' : undefined}
    >
      {link.label}
    </a>
  ))}
</nav>
