---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyncNav from '../../components/SyncNav.astro';
import { getSessionFromContext } from '../../lib/session';
import { db } from '../../db';
import { count, eq } from 'drizzle-orm';
import { syncRuns, userStorageConnections } from '../../db/schema';

const session = await getSessionFromContext(Astro);
if (!session?.user) return Astro.redirect('/login');
const pageSize = 20;
const requestedPage = Number.parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const [runCount] = await db.select({ value: count() }).from(syncRuns).where(eq(syncRuns.userId, session.user.id));
const totalRuns = Number(runCount?.value ?? 0);
const totalPages = Math.max(1, Math.ceil(totalRuns / pageSize));
const currentPage = Number.isFinite(requestedPage) ? Math.min(Math.max(requestedPage, 1), totalPages) : 1;
const runs = await db.query.syncRuns.findMany({ where: eq(syncRuns.userId, session.user.id), orderBy: (table, { desc }) => [desc(table.createdAt)], limit: pageSize, offset: (currentPage - 1) * pageSize });
const connections = await db.query.userStorageConnections.findMany({ where: eq(userStorageConnections.userId, session.user.id) });
const names = new Map(connections.map((connection) => [connection.id, connection.providerName]));
const activeStatuses = ['queued', 'running', 'retrying', 'cancellation_requested'];

function progressFor(run: typeof syncRuns.$inferSelect) {
  const processed = run.filesUploaded + run.filesSkipped + run.filesFailed;
  const percent = run.filesDiscovered > 0 ? Math.min(100, Math.round((processed / run.filesDiscovered) * 100)) : 0;
  const workerStale = run.status === 'queued' && Date.now() - run.createdAt.getTime() > 120_000;
  const label = run.filesDiscovered > 0
    ? `${processed} of ${run.filesDiscovered} files processed`
    : run.status === 'queued' ? (workerStale ? 'Worker may be offline — this job has waited over two minutes.' : 'Awaiting worker…') : 'Preparing sync…';
  return { processed, percent, label };
}
---

<BaseLayout title="Sync Activity - TailCache" isAuthenticated={true}>
  <div class="app-page">
    <div class="app-header">
      <div>
        <p class="app-kicker">Sync history</p>
        <h1 class="app-title">Activity</h1>
        <p class="app-description">Every run, partial upload, and provider error is recorded here.</p>
      </div>
    </div>
    <SyncNav current="status" />

    <section class="app-panel-raised overflow-hidden">
      <div class="flex items-center justify-between border-b border-white/10 px-6 py-4">
        <h2 class="font-semibold text-white">Sync logs</h2>
        <div class="flex items-center gap-4">
          <span class="text-xs text-zinc-500">{totalRuns === 0 ? 'No runs' : `Showing ${(currentPage - 1) * pageSize + 1}–${Math.min(currentPage * pageSize, totalRuns)} of ${totalRuns}`}</span>
          <span id="activity-refresh-state" class="text-xs text-zinc-500">Live while running</span>
        </div>
      </div>
      {runs.length === 0 ? (
        <div class="p-8 text-center text-sm text-zinc-500">No sync runs yet.</div>
      ) : (
        <div class="divide-y divide-white/5">
          {runs.map((run) => {
            const progress = progressFor(run);
            const active = activeStatuses.includes(run.status);
            return (
              <details class="group px-6 py-4" data-activity-detail data-run-card={run.id} data-active={active ? 'true' : 'false'}>
                <summary class="flex cursor-pointer list-none items-center justify-between gap-4">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-3">
                      <span
                        data-run-status
                        class:list={[
                          'rounded-full px-2 py-1 text-xs',
                          ['queued', 'running', 'retrying'].includes(run.status) ? 'bg-indigo-400/10 text-indigo-300' :
                            run.status === 'completed' ? 'bg-emerald-400/10 text-emerald-300' :
                              run.status === 'partial' ? 'bg-amber-400/10 text-amber-300' :
                                ['cancelled', 'cancellation_requested'].includes(run.status) ? 'bg-zinc-400/10 text-zinc-300' :
                                  'bg-red-400/10 text-red-300',
                        ]}
                      >
                        {run.status === 'cancellation_requested' ? 'stopping' : run.status}
                      </span>
                      <span class="truncate text-sm font-medium text-white">{names.get(run.connectionId) ?? 'Destination'}</span>
                    </div>
                    <p data-run-progress-label class="mt-2 text-xs text-zinc-500">
                      {progress.label} · {run.filesUploaded} uploaded · {run.filesFailed} failed
                    </p>
                    <div class="mt-3 h-1.5 max-w-xl overflow-hidden rounded-full bg-white/10">
                      <div data-run-progress class="h-full rounded-full bg-indigo-400 transition-[width] duration-500" style={`width: ${progress.percent}%`}></div>
                    </div>
                  </div>
                  <div class="flex items-center gap-3">
                    <button type="button" data-cancel-run={run.id} class:list={['rounded-lg border border-red-400/20 px-3 py-1.5 text-xs text-red-300 hover:bg-red-400/10', !['running', 'queued', 'retrying'].includes(run.status) && 'hidden']}>Stop</button>
                    <span class="text-zinc-500 transition-transform group-open:rotate-180">⌄</span>
                  </div>
                </summary>
                {(run.errorSummary || run.filesFailed > 0) && (
                  <div data-run-error class="mt-4 rounded-lg border border-red-400/15 bg-red-400/[0.06] p-3 text-sm text-red-200">
                    <p>{run.failureCode ? `${run.failureCode}: ` : ''}{run.errorSummary ?? `${run.filesFailed} file(s) failed`}</p>
                    <p class="mt-2 text-xs text-red-300/70">Run ID: {run.id}</p>
                  </div>
                )}
                <div class="mt-4" data-run-failures aria-live="polite"></div>
              </details>
            );
          })}
        </div>
      )}
    </section>

    {totalPages > 1 && (
      <nav class="mt-5 flex items-center justify-between" aria-label="Activity pagination">
        {currentPage > 1 ? (
          <a href={`/sync/status?page=${currentPage - 1}`} class="rounded-lg border border-white/10 px-3 py-2 text-sm text-zinc-300 hover:bg-white/5">← Newer</a>
        ) : <span></span>}
        <span class="text-sm text-zinc-500">Page {currentPage} of {totalPages}</span>
        {currentPage < totalPages ? (
          <a href={`/sync/status?page=${currentPage + 1}`} class="rounded-lg border border-white/10 px-3 py-2 text-sm text-zinc-300 hover:bg-white/5">Older →</a>
        ) : <span></span>}
      </nav>
    )}
  </div>
</BaseLayout>

<script>
  const activeStatuses = ['queued', 'running', 'retrying', 'cancellation_requested'];
  const statusClassNames = ['bg-indigo-400/10', 'text-indigo-300', 'bg-emerald-400/10', 'text-emerald-300', 'bg-amber-400/10', 'text-amber-300', 'bg-zinc-400/10', 'text-zinc-300', 'bg-red-400/10', 'text-red-300'];
  const refreshState = document.querySelector<HTMLElement>('#activity-refresh-state');
  const failureRefreshTimers = new Map<string, number>();

  document.querySelectorAll<HTMLDetailsElement>('[data-activity-detail]').forEach((detail) => {
    detail.open = false;
  });

  function statusClasses(status: string) {
    if (['queued', 'running', 'retrying'].includes(status)) return ['bg-indigo-400/10', 'text-indigo-300'];
    if (status === 'completed') return ['bg-emerald-400/10', 'text-emerald-300'];
    if (status === 'partial') return ['bg-amber-400/10', 'text-amber-300'];
    if (['cancelled', 'cancellation_requested'].includes(status)) return ['bg-zinc-400/10', 'text-zinc-300'];
    return ['bg-red-400/10', 'text-red-300'];
  }

  function updateRunCard(run: { id: string; status: string; filesDiscovered: number; filesUploaded: number; filesSkipped: number; filesFailed: number; createdAt?: string; errorSummary?: string | null }) {
    const card = document.querySelector<HTMLElement>(`[data-run-card="${run.id}"]`);
    if (!card) return;
    const processed = run.filesUploaded + run.filesSkipped + run.filesFailed;
    const percent = run.filesDiscovered > 0 ? Math.min(100, Math.round((processed / run.filesDiscovered) * 100)) : 0;
    const status = card.querySelector<HTMLElement>('[data-run-status]');
    const progress = card.querySelector<HTMLElement>('[data-run-progress]');
    const label = card.querySelector<HTMLElement>('[data-run-progress-label]');
    const cancel = card.querySelector<HTMLButtonElement>('[data-cancel-run]');
    if (status) {
      status.classList.remove(...statusClassNames);
      status.classList.add(...statusClasses(run.status));
      status.textContent = run.status === 'cancellation_requested' ? 'stopping' : run.status;
    }
    if (progress) progress.style.width = `${percent}%`;
    const staleWorker = run.status === 'queued' && run.createdAt && Date.now() - new Date(run.createdAt).getTime() > 120_000;
    if (label) label.textContent = run.filesDiscovered > 0 ? `${processed} of ${run.filesDiscovered} files processed · ${run.filesUploaded} uploaded · ${run.filesFailed} failed` : run.status === 'queued' ? (staleWorker ? 'Worker may be offline — this job has waited over two minutes.' : 'Awaiting worker…') : 'Preparing sync…';
    if (cancel) cancel.classList.toggle('hidden', !['running', 'queued', 'retrying'].includes(run.status));
    card.dataset.active = activeStatuses.includes(run.status) ? 'true' : 'false';
  }

  type Failure = {
    itemKind: 'file' | 'thumbnail' | 'metadata';
    itemName: string;
    destinationKey: string;
    errorMessage: string;
    failureCode: string;
    httpStatus: number | null;
    retryable: boolean;
    status: 'failed' | 'recovered';
    attemptCount: number;
    lastFailedAt: string;
    resolvedAt: string | null;
  };

  function detailLine(label: string, value: string) {
    const line = document.createElement('p');
    line.className = 'mt-1 break-all text-xs text-zinc-400';
    const strong = document.createElement('span');
    strong.className = 'text-zinc-300';
    strong.textContent = `${label}: `;
    line.append(strong, value);
    return line;
  }

  function renderFailures(card: HTMLElement, failures: Failure[], diagnosticsAvailable = true) {
    const container = card.querySelector<HTMLElement>('[data-run-failures]');
    if (!container) return;
    container.replaceChildren();
    if (!diagnosticsAvailable) {
      const notice = document.createElement('p');
      notice.className = 'rounded-lg border border-amber-400/15 bg-amber-400/[0.06] p-3 text-sm text-amber-200';
      notice.textContent = 'Failure details will appear after the pending database migration is applied.';
      container.append(notice);
      return;
    }
    if (failures.length === 0) return;

    const heading = document.createElement('h3');
    heading.className = 'mb-2 text-sm font-medium text-white';
    heading.textContent = 'Failed items';
    const list = document.createElement('div');
    list.className = 'space-y-2';
    for (const failure of failures) {
      const item = document.createElement('div');
      item.className = failure.status === 'recovered'
        ? 'rounded-lg border border-emerald-400/15 bg-emerald-400/[0.04] p-3'
        : 'rounded-lg border border-red-400/15 bg-red-400/[0.06] p-3';
      const title = document.createElement('p');
      title.className = 'text-sm font-medium text-white';
      title.textContent = failure.itemName;
      const state = document.createElement('span');
      state.className = failure.status === 'recovered' ? 'ml-2 text-xs text-emerald-300' : 'ml-2 text-xs text-red-300';
      state.textContent = failure.status === 'recovered' ? `recovered after ${failure.attemptCount} failed attempt${failure.attemptCount === 1 ? '' : 's'}` : `${failure.attemptCount} failed attempt${failure.attemptCount === 1 ? '' : 's'}`;
      title.append(state);
      item.append(
        title,
        detailLine(failure.destinationKey === '__sync_run__' ? 'Scope' : 'Path', failure.destinationKey === '__sync_run__' ? 'Entire sync run' : failure.destinationKey),
        detailLine('Error', `${failure.failureCode}${failure.httpStatus ? ` (HTTP ${failure.httpStatus})` : ''}: ${failure.errorMessage}`),
        detailLine('Retry', failure.retryable ? 'Automatic retry is available' : 'Not retryable'),
      );
      list.append(item);
    }
    container.append(heading, list);
  }

  async function loadFailures(card: HTMLElement) {
    const runId = card.dataset.runCard;
    if (!runId) return;
    try {
      const response = await fetch(`/api/sync/runs/${runId}`);
      if (!response.ok) return;
      const payload = await response.json() as { failures?: Failure[]; diagnosticsAvailable?: boolean };
      renderFailures(card, payload.failures ?? [], payload.diagnosticsAvailable !== false);
    } catch {
      // The existing run summary remains available if this optional detail load fails.
    }
  }

  function scheduleFailuresRefresh(card: HTMLElement) {
    const runId = card.dataset.runCard;
    if (!runId || failureRefreshTimers.has(runId)) return;
    const timer = window.setTimeout(() => {
      failureRefreshTimers.delete(runId);
      if (card.matches('details[open]')) void loadFailures(card);
    }, 1_500);
    failureRefreshTimers.set(runId, timer);
  }

  document.querySelectorAll<HTMLDetailsElement>('[data-activity-detail]').forEach((detail) => {
    detail.addEventListener('toggle', () => {
      if (detail.open) void loadFailures(detail);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-cancel-run]').forEach((button) => {
    button.addEventListener('click', async (event) => {
      event.preventDefault();
      event.stopPropagation();
      button.disabled = true;
      button.textContent = 'Stopping…';
      const response = await fetch(`/api/sync/runs/${button.dataset.cancelRun}`, { method: 'DELETE' });
      if (response.ok) {
      } else {
        button.disabled = false;
        button.textContent = 'Stop';
      }
    });
  });

  const events = new EventSource('/api/sync/events');
  events.onopen = () => {
    if (refreshState) refreshState.textContent = 'Live updates';
  };
  events.onmessage = (event) => {
    const payload = JSON.parse(event.data) as { runs?: Array<{ id: string; status: string; filesDiscovered: number; filesUploaded: number; filesSkipped: number; filesFailed: number; createdAt?: string; errorSummary?: string | null }>; run?: { id: string; status: string; filesDiscovered: number; filesUploaded: number; filesSkipped: number; filesFailed: number; createdAt?: string; errorSummary?: string | null } };
    payload.runs?.forEach((run) => {
      updateRunCard(run);
      const card = document.querySelector<HTMLElement>(`[data-run-card="${run.id}"]`);
      if (card?.matches('details[open]')) scheduleFailuresRefresh(card);
    });
    if (payload.run) {
      updateRunCard(payload.run);
      const card = document.querySelector<HTMLElement>(`[data-run-card="${payload.run.id}"]`);
      if (card?.matches('details[open]')) scheduleFailuresRefresh(card);
    }
  };
  events.onerror = () => {
    if (refreshState) refreshState.textContent = 'Reconnecting…';
  };
</script>
