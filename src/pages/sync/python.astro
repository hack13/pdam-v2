---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PythonSyncManager } from '../../components/PythonSyncManager';
import SyncNav from '../../components/SyncNav.astro';
---

<BaseLayout title="Python Sync - PDAM" isAuthenticated={true}>
  <div class="mx-auto max-w-7xl px-6 py-10"><div class="mb-8"><p class="text-xs font-semibold uppercase tracking-[0.22em] text-indigo-300">Sync</p><h1 class="mt-2 text-3xl font-bold text-white">Python Sync</h1><p class="mt-2 max-w-2xl text-sm text-zinc-400">Use the readable Python client when your browser cannot write directly to a local folder.</p></div><SyncNav current="python" /><PythonSyncManager client:load /></div>
</BaseLayout>
