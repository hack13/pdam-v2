---
interface Props {
  current: 'assets' | 'marketplaces' | 'creators';
}

const { current } = Astro.props;
---

<nav aria-label="Library sections" class="app-nav">
  <a href="/library" class="app-nav-link" aria-current={current === 'assets' ? 'page' : undefined}>
    Assets
  </a>
  <a href="/library/marketplaces" class="app-nav-link" aria-current={current === 'marketplaces' ? 'page' : undefined}>
    Marketplaces
  </a>
  <a href="/library/creators" class="app-nav-link" aria-current={current === 'creators' ? 'page' : undefined}>
    Creators
  </a>
</nav>
