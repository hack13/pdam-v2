---
import { UserMenu } from './UserMenu';
import BrandMark from './BrandMark.astro';
import { getSessionFromContext } from '../lib/session';
import { db } from '../db';
import { users } from '../db/schema';
import { eq } from 'drizzle-orm';
import { isAdminUser } from '../lib/admin';
import { isCreatorUser } from '../lib/creator';

interface Props {
  isAuthenticated: boolean;
}

const { isAuthenticated } = Astro.props;
const session = isAuthenticated ? await getSessionFromContext(Astro) : null;
const userName = session?.user?.name ?? '';

let isAdmin = false;
let isCreator = false;
let userImage = '';
if (session?.user) {
  const user = await db.query.users.findFirst({
    where: eq(users.id, session.user.id),
  });
  if (user) {
    isAdmin = isAdminUser(user);
    isCreator = isCreatorUser(user);
    userImage = user.image ?? '';
  }
}

const fallbackAvatarUrl = userName
  ? `https://ui-avatars.com/api/?name=${encodeURIComponent(userName)}&background=7e3ff2&color=fff`
  : '';
const pathname = Astro.url.pathname;
const isActive = (href: string) => href === '/gallery'
  ? pathname.startsWith('/gallery')
  : pathname === href || pathname.startsWith(`${href}/`) || (href === '/library' && pathname.startsWith('/assets'));
---

<nav class="fixed inset-x-0 top-0 z-50 border-b border-white/10 bg-[#090d14]/85 backdrop-blur-xl">
  <div class="mx-auto flex h-[72px] max-w-7xl items-center justify-between px-5 sm:px-6">
    <a href="/" class="flex items-center gap-3" aria-label="PDAM home">
      <BrandMark class="h-10 w-9 object-contain" alt="" />
      <span class="font-display text-base font-bold tracking-[0.12em] text-white">PDAM</span>
    </a>

    {isAuthenticated ? (
      <div class="hidden items-center gap-7 md:flex">
        <a href="/library" aria-current={isActive('/library') ? 'page' : undefined} class:list={["relative text-sm font-medium transition-colors hover:text-white after:absolute after:-bottom-[27px] after:left-0 after:right-0 after:h-px after:bg-indigo-400", isActive('/library') ? 'text-white after:opacity-100' : 'text-zinc-400 after:opacity-0']}>Library</a>
        <a href="/gallery" aria-current={isActive('/gallery') ? 'page' : undefined} class:list={["relative text-sm font-medium transition-colors hover:text-white after:absolute after:-bottom-[27px] after:left-0 after:right-0 after:h-px after:bg-indigo-400", isActive('/gallery') ? 'text-white after:opacity-100' : 'text-zinc-400 after:opacity-0']}>Gallery</a>
        <a href="/sync" aria-current={isActive('/sync') ? 'page' : undefined} class:list={["relative text-sm font-medium transition-colors hover:text-white after:absolute after:-bottom-[27px] after:left-0 after:right-0 after:h-px after:bg-indigo-400", isActive('/sync') ? 'text-white after:opacity-100' : 'text-zinc-400 after:opacity-0']}>Sync</a>
        {isCreator && <a href="/creator" aria-current={isActive('/creator') ? 'page' : undefined} class:list={["relative text-sm font-medium transition-colors hover:text-white after:absolute after:-bottom-[27px] after:left-0 after:right-0 after:h-px after:bg-indigo-400", isActive('/creator') ? 'text-white after:opacity-100' : 'text-zinc-400 after:opacity-0']}>Studio</a>}
        <UserMenu
          client:load
          userName={userName}
          userImage={userImage}
          fallbackAvatarUrl={fallbackAvatarUrl}
          isAdmin={isAdmin}
          isCreator={isCreator}
          showCreatorApply={!isCreator}
        />
      </div>
    ) : (
      <div class="hidden items-center gap-7 md:flex">
        <a href="/gallery" class="text-sm font-medium text-zinc-400 transition-colors hover:text-white">Gallery</a>
        <a href="/#features" class="text-sm font-medium text-zinc-400 transition-colors hover:text-white">Features</a>
        <a href="/#workflow" class="text-sm font-medium text-zinc-400 transition-colors hover:text-white">Workflow</a>
        <a href="/login" class="btn-primary !px-5 !py-2.5">Sign in</a>
      </div>
    )}

    <details class="group relative md:hidden">
      <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-xl border border-white/10 bg-white/5 text-zinc-300 transition-colors hover:bg-white/10 hover:text-white [&::-webkit-details-marker]:hidden" aria-label="Open navigation">
        <svg class="h-5 w-5 group-open:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path stroke-linecap="round" d="M5 8h14M5 16h14" />
        </svg>
        <svg class="hidden h-5 w-5 group-open:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
          <path stroke-linecap="round" d="m7 7 10 10M17 7 7 17" />
        </svg>
      </summary>
      <div class="absolute right-0 mt-3 w-56 overflow-hidden rounded-2xl border border-white/10 bg-[#121722] p-2 shadow-2xl shadow-black/40">
        {isAuthenticated ? (
          <>
            <a href="/library" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Library</a>
            <a href="/gallery" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Gallery</a>
            <a href="/sync" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Sync</a>
            {isCreator && <a href="/creator" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Creator studio</a>}
            <a href="/dashboard" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Account</a>
          </>
        ) : (
          <>
            <a href="/gallery" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Gallery</a>
            <a href="/#features" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Features</a>
            <a href="/#workflow" class="block rounded-xl px-4 py-3 text-sm text-zinc-300 hover:bg-white/5 hover:text-white">Workflow</a>
            <a href="/login" class="mt-1 block rounded-xl bg-indigo-500 px-4 py-3 text-center text-sm font-semibold text-white">Sign in</a>
          </>
        )}
      </div>
    </details>
  </div>
</nav>
