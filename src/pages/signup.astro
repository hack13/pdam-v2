---
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandMark from '../components/BrandMark.astro';
import { SignUpForm } from '../components/SignUpForm';
import { getSessionFromContext } from '../lib/session';

const session = await getSessionFromContext(Astro);
const isAuthenticated = !!session?.user;
const inviteCode = Astro.url.searchParams.get('invite')?.trim().slice(0, 200) ?? '';

if (isAuthenticated) {
  return Astro.redirect('/dashboard');
}
---

<BaseLayout title="Create Account - PDAM" isAuthenticated={isAuthenticated}>
  <div class="relative flex min-h-[calc(100vh-72px)] items-center justify-center overflow-hidden px-6 py-16">
    <div class="pointer-events-none absolute left-1/2 top-0 h-96 w-96 -translate-x-1/2 rounded-full bg-indigo-500/10 blur-3xl" aria-hidden="true"></div>
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <BrandMark class="mx-auto mb-5 h-16 w-14 object-contain" />
        <h1 class="text-3xl font-semibold text-white">Create your account</h1>
        <p class="mt-2 text-sm text-zinc-400">PDAM is invite-only during the private beta.</p>
      </div>

      <div class="brand-panel rounded-[22px] p-8">
        <SignUpForm initialInviteCode={inviteCode} client:load />
      </div>
    </div>
  </div>
</BaseLayout>
