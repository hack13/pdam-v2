---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { FeedbackWidget } from '../components/FeedbackWidget';
import '../styles/global.css';

interface Props {
  title: string;
  isAuthenticated: boolean;
}

const { title, isAuthenticated } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#080C14" />
    <meta name="description" content="TailCache keeps your digital assets organized, owned, versioned, and ready to sync." />
    <link rel="icon" type="image/png" href="/brand/tailcache-crystal-tail.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="flex min-h-screen flex-col text-white antialiased">
    <Navbar isAuthenticated={isAuthenticated} />
    <main class="flex-1 pt-[72px]">
      <slot />
    </main>
    <Footer isAuthenticated={isAuthenticated} />
    {isAuthenticated && <FeedbackWidget client:load />}
  </body>
</html>
