---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GalleryNav from '../../components/GalleryNav.astro';
import { getSessionFromContext } from '../../lib/session';
import { db } from '../../db';
import {
  products,
  creators,
  galleryPurchaseLinks,
  marketplaceSources,
  fileThumbnails,
} from '../../db/schema';
import { and, desc, eq, ilike, inArray, lt, or } from 'drizzle-orm';

const PAGE_SIZE = 24;
const search = Astro.url.searchParams.get('q')?.trim() ?? '';
const cursorValue = Astro.url.searchParams.get('cursor');
let cursor: { updatedAt: string; id: string } | null = null;
if (cursorValue) {
  try {
    const decoded = JSON.parse(Buffer.from(cursorValue, 'base64url').toString('utf8')) as { updatedAt?: string; id?: string };
    if (decoded.updatedAt && decoded.id) cursor = { updatedAt: decoded.updatedAt, id: decoded.id };
  } catch {
    // Ignore malformed cursors and serve the first page.
  }
}

const galleryWhere = [
  eq(products.isGalleryListed, true),
  ...(search ? [or(ilike(products.title, `%${search}%`), ilike(products.descriptionText, `%${search}%`))!] : []),
  ...(cursor ? [or(
    lt(products.updatedAt, new Date(cursor.updatedAt)),
    and(eq(products.updatedAt, new Date(cursor.updatedAt)), lt(products.id, cursor.id)),
  )!] : []),
];

const session = await getSessionFromContext(Astro);
const isAuthenticated = !!session?.user;

const fetchedListings = await db.query.products.findMany({
  where: and(...galleryWhere),
  orderBy: [desc(products.updatedAt), desc(products.id)],
  limit: PAGE_SIZE + 1,
  columns: {
    id: true,
    creatorIds: true,
    title: true,
    tags: true,
    thumbnailFileThumbnailId: true,
    sourceProductId: true,
    updatedAt: true,
  },
});
const hasNextPage = fetchedListings.length > PAGE_SIZE;
const listings = fetchedListings.slice(0, PAGE_SIZE);
const nextCursor = hasNextPage && listings.length > 0
  ? Buffer.from(JSON.stringify({ updatedAt: listings[listings.length - 1].updatedAt.toISOString(), id: listings[listings.length - 1].id })).toString('base64url')
  : null;

const thumbIds = listings
  .map((l) => l.thumbnailFileThumbnailId)
  .filter((id): id is string => !!id);
const thumbs =
  thumbIds.length > 0
    ? await db.query.fileThumbnails.findMany({
        where: inArray(fileThumbnails.id, thumbIds),
      })
    : [];
const thumbSet = new Set(thumbs.map((t) => t.id));

const allCreatorIds = [...new Set(listings.flatMap((l) => l.creatorIds ?? []))];
const creatorsList =
  allCreatorIds.length > 0
    ? await db.query.creators.findMany({
        where: inArray(creators.id, allCreatorIds),
      })
    : [];
const creatorMap = Object.fromEntries(creatorsList.map((c) => [c.id, c]));

const listingIds = listings.map((l) => l.id);
const links =
  listingIds.length > 0
    ? await db.query.galleryPurchaseLinks.findMany({
        where: inArray(galleryPurchaseLinks.productId, listingIds),
      })
    : [];

const marketplaceIds = [...new Set(links.map((l) => l.marketplaceSourceId))];
const markets =
  marketplaceIds.length > 0
    ? await db.query.marketplaceSources.findMany({
        where: inArray(marketplaceSources.id, marketplaceIds),
      })
    : [];
const marketplaceMap = Object.fromEntries(markets.map((m) => [m.id, m]));

const linksByProduct = new Map<string, typeof links>();
for (const link of links) {
  const productLinks = linksByProduct.get(link.productId) ?? [];
  productLinks.push(link);
  linksByProduct.set(link.productId, productLinks);
}

let ownedSourceIds = new Set<string>();
if (session?.user && listingIds.length > 0) {
  const owned = await db.query.products.findMany({
    where: and(eq(products.ownerUserId, session.user.id), inArray(products.sourceProductId, listingIds)),
    columns: { sourceProductId: true },
  });
  ownedSourceIds = new Set(
    owned.map((o) => o.sourceProductId).filter((id): id is string => !!id),
  );
}
---

<BaseLayout title="Gallery - TailCache" isAuthenticated={isAuthenticated}>
  <div class="app-page">
    <div class="app-header">
      <div>
        <p class="app-kicker">Creator marketplace</p>
        <h1 class="app-title">Gallery</h1>
        <p class="app-description">Browse creator listings and verify ownership to add assets to your library.</p>
      </div>
    </div>

    <GalleryNav current="assets" />

    <form method="get" action="/gallery" class="mb-6">
      <div class="relative">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="gallery-search"
          type="text"
          name="q"
          aria-label="Search assets"
          value={search}
          placeholder="Search gallery…"
          class="field-control !pl-11"
        />
      </div>
    </form>

    {listings.length === 0 ? (
      <div class="rounded-xl border border-dashed border-white/10 bg-white/5 p-12 text-center">
        <h3 class="text-lg font-medium text-white">No listings yet</h3>
        <p class="mt-1 text-sm text-zinc-400">Creators haven&apos;t published any gallery items.</p>
      </div>
    ) : (
      <div id="gallery-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {listings.map((listing) => {
          const thumbUrl =
            listing.thumbnailFileThumbnailId && thumbSet.has(listing.thumbnailFileThumbnailId)
              ? `/api/thumbnail/${listing.thumbnailFileThumbnailId}`
              : null;
          const listingCreators = (listing.creatorIds ?? [])
            .map((id) => creatorMap[id])
            .filter(Boolean);
          const listingLinks = linksByProduct.get(listing.id) ?? [];
          const marketNames = listingLinks
            .map((l) => marketplaceMap[l.marketplaceSourceId]?.name)
            .filter(Boolean);
          const searchTerms = [
            listing.title.toLowerCase(),
            ...(listing.tags ?? []).map((t: string) => t.toLowerCase()),
            ...listingCreators.map((c) => c.name.toLowerCase()),
            ...marketNames.map((n) => n!.toLowerCase()),
          ].join(' ');
          const owned = ownedSourceIds.has(listing.id);

          return (
            <a
              href={`/gallery/${listing.id}`}
              data-search={searchTerms}
              class="gallery-card group flex flex-col overflow-hidden rounded-xl border border-white/10 bg-white/5 backdrop-blur-sm transition-all hover:border-white/20 hover:bg-white/[0.07]"
            >
              <div class="relative aspect-square overflow-hidden bg-zinc-900">
                {thumbUrl ? (
                  <img src={thumbUrl} alt={listing.title} class="h-full w-full object-cover transition-transform group-hover:scale-105" />
                ) : (
                  <div class="flex h-full items-center justify-center text-zinc-700">
                    <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
                {owned && (
                  <span class="absolute right-2 top-2 rounded-md bg-emerald-500/90 px-2 py-0.5 text-[10px] font-medium text-white">
                    In library
                  </span>
                )}
              </div>
              <div class="flex flex-1 flex-col p-3">
                <h3 class="truncate font-medium text-white">{listing.title}</h3>
                {listingCreators.length > 0 && (
                  <p class="truncate text-xs text-zinc-500">
                    by <span class="font-medium text-zinc-400">{listingCreators.map((c) => c.name).join(', ')}</span>
                  </p>
                )}
                {marketNames.length > 0 && (
                  <p class="mt-1 truncate text-xs text-zinc-500">
                    {marketNames.join(' · ')}
                  </p>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}

    {nextCursor && (
      <div class="mt-8 flex justify-center">
        <a
          href={`/gallery?${new URLSearchParams({ ...(search ? { q: search } : {}), cursor: nextCursor })}`}
          class="btn-secondary"
        >
          Next page
        </a>
      </div>
    )}

    <div id="no-results" class="hidden rounded-xl border border-dashed border-white/10 bg-white/5 p-12 text-center">
      <h3 class="text-lg font-medium text-white">No listings found</h3>
      <p class="mt-1 text-sm text-zinc-400">Try a different search term.</p>
    </div>
  </div>

  <script>
    const input = document.getElementById('gallery-search') as HTMLInputElement;
    const grid = document.getElementById('gallery-grid');
    const noResults = document.getElementById('no-results')!;

    if (input && grid) {
      input.addEventListener('input', () => {
        const query = input.value.toLowerCase().trim();
        const cards = grid.querySelectorAll('.gallery-card') as NodeListOf<HTMLElement>;
        let visible = 0;
        cards.forEach((card) => {
          const matches = !query || (card.dataset.search ?? '').includes(query);
          card.style.display = matches ? '' : 'none';
          if (matches) visible++;
        });
        grid.style.display = visible === 0 && query ? 'none' : '';
        noResults.classList.toggle('hidden', !(visible === 0 && query));
      });
    }
  </script>
</BaseLayout>
