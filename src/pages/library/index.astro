---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LibraryNav from '../../components/LibraryNav.astro';
import { getSessionFromContext } from '../../lib/session';
import { db } from '../../db';
import { products } from '../../db/schema';
import { and, desc, eq, ilike, inArray, lt, or } from 'drizzle-orm';

const PAGE_SIZE = 24;
const search = Astro.url.searchParams.get('q')?.trim() ?? '';
const cursorValue = Astro.url.searchParams.get('cursor');
let cursor: { createdAt: string; id: string } | null = null;
if (cursorValue) {
  try {
    const decoded = JSON.parse(Buffer.from(cursorValue, 'base64url').toString('utf8')) as { createdAt?: string; id?: string };
    if (decoded.createdAt && decoded.id) cursor = { createdAt: decoded.createdAt, id: decoded.id };
  } catch {
    // Ignore malformed cursors and serve the first page.
  }
}

const session = await getSessionFromContext(Astro);

if (!session?.user) {
  return Astro.redirect('/login');
}

const { user } = session;
const isAuthenticated = true;

const libraryWhere = [
  eq(products.ownerUserId, user.id),
  ...(search ? [or(ilike(products.title, `%${search}%`), ilike(products.descriptionText, `%${search}%`))!] : []),
  ...(cursor ? [or(
    lt(products.createdAt, new Date(cursor.createdAt)),
    and(eq(products.createdAt, new Date(cursor.createdAt)), lt(products.id, cursor.id)),
  )!] : []),
];

const fetchedAssets = await db.query.products.findMany({
  where: and(...libraryWhere),
  orderBy: [desc(products.createdAt), desc(products.id)],
  limit: PAGE_SIZE + 1,
  columns: {
    id: true,
    creatorIds: true,
    title: true,
    tags: true,
    thumbnailFileThumbnailId: true,
    marketplaceSourceId: true,
    productUrl: true,
    sourceProductId: true,
    createdAt: true,
  },
});
const hasNextPage = fetchedAssets.length > PAGE_SIZE;
const userAssets = fetchedAssets.slice(0, PAGE_SIZE);
const nextCursor = hasNextPage && userAssets.length > 0
  ? Buffer.from(JSON.stringify({ createdAt: userAssets[userAssets.length - 1].createdAt.toISOString(), id: userAssets[userAssets.length - 1].id })).toString('base64url')
  : null;

const thumbnails = userAssets.length > 0
  ? await db.query.fileThumbnails.findMany({
      where: (table, { inArray }) => {
        const thumbIds = userAssets
          .map((a) => a.thumbnailFileThumbnailId)
          .filter((id): id is string => !!id);
        return thumbIds.length > 0 ? inArray(table.id, thumbIds) : inArray(table.id, []);
      },
    })
  : [];
const thumbnailMap = Object.fromEntries(thumbnails.map((t) => [t.id, t]));

const marketplaceIds = userAssets
  .map((a) => a.marketplaceSourceId)
  .filter((id): id is string => !!id);
const marketplaceSourcesList = marketplaceIds.length > 0
  ? await db.query.marketplaceSources.findMany({
      where: (table) => inArray(table.id, marketplaceIds),
    })
  : [];
const marketplaceSourceMap = Object.fromEntries(marketplaceSourcesList.map((s) => [s.id, s]));

const allCreatorIds = [
  ...new Set(
    userAssets
      .flatMap((a) => a.creatorIds ?? [])
  ),
];
const creatorsList = allCreatorIds.length > 0
  ? await db.query.creators.findMany({
      where: (table) => inArray(table.id, allCreatorIds),
    })
  : [];
const creatorMap = Object.fromEntries(creatorsList.map((c) => [c.id, c]));
---

<BaseLayout title="Library - TailCache" isAuthenticated={isAuthenticated}>
  <div class="app-page">
    <div class="app-header">
      <div>
        <p class="app-kicker">Personal asset archive</p>
        <h1 class="app-title">Library</h1>
        <p class="app-description">Every purchase, creator, license, and version in one searchable record.</p>
      </div>
      <a href="/assets/new" class="btn-primary">
        <svg class="mr-1.5 h-4 w-4 inline" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
        </svg>
        New asset
      </a>
    </div>

    <LibraryNav current="assets" />

    <form method="get" action="/library" class="mb-6">
      <div class="relative">
        <svg class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input
          id="library-search"
          type="text"
          name="q"
          value={search}
          placeholder={`Search ${userAssets.length} assets by title, creator, marketplace, or tag…`}
          class="field-control !pl-11"
        />
      </div>
    </form>

    {userAssets.length === 0 ? (
      <div class="rounded-xl border border-dashed border-white/10 bg-white/5 p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-white">No assets yet</h3>
        <p class="mt-1 text-sm text-zinc-400">Create your first asset to start organizing your VR library.</p>
        <a href="/assets/new" class="btn-primary mt-4 inline-flex">Create first asset</a>
      </div>
    ) : (
      <div id="asset-grid" class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {userAssets.map((asset) => {
          const thumbRecord = asset.thumbnailFileThumbnailId
            ? thumbnailMap[asset.thumbnailFileThumbnailId]
            : null;
          const thumbUrl = thumbRecord ? `/api/thumbnail/${thumbRecord.id}` : null;
          const marketplaceSource = asset.marketplaceSourceId
            ? marketplaceSourceMap[asset.marketplaceSourceId]
            : null;
          const assetCreators = (asset.creatorIds ?? [])
            .map((id) => creatorMap[id])
            .filter(Boolean);
          const searchTerms = [
            asset.title.toLowerCase(),
            ...(asset.tags ?? []).map((t: string) => t.toLowerCase()),
            ...(marketplaceSource ? [marketplaceSource.name.toLowerCase()] : []),
            ...assetCreators.map((c) => c.name.toLowerCase()),
          ].join(' ');
          return (
            <a
              href={`/assets/${asset.id}`}
              data-search={searchTerms}
              class="asset-card asset-card-brand group"
            >
              <div class="aspect-square overflow-hidden bg-zinc-900">
                {thumbUrl ? (
                  <img src={thumbUrl} alt={asset.title} class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.025]" />
                ) : (
                  <div class="flex h-full items-center justify-center text-zinc-700">
                    <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                )}
              </div>
              <div class="flex flex-1 flex-col p-4">
                <h3 class="truncate font-display font-semibold text-white">{asset.title}</h3>
                {assetCreators.length > 0 && (
                  <p class="truncate text-xs text-zinc-500">
                    by <span class="font-medium text-zinc-400">{assetCreators.map((c) => c.name).join(', ')}</span>
                  </p>
                )}
                {marketplaceSource ? (
                  <p class="mt-1 truncate text-xs">
                    <span class="font-medium text-zinc-400">{marketplaceSource.name}</span>
                    {asset.productUrl && (
                      <span class="ml-1.5 text-indigo-400">· Link stored</span>
                    )}
                  </p>
                ) : null}
                {asset.sourceProductId && (
                  <p class="mt-1 text-[10px] font-medium uppercase tracking-wide text-emerald-400/90">
                    Linked from gallery
                  </p>
                )}
                {asset.tags && asset.tags.length > 0 ? (
                  <div class="mt-1 flex flex-wrap gap-1">
                    {asset.tags.map((tag: string) => (
                      <span class="tag-chip">
                        {tag}
                      </span>
                    ))}
                  </div>
                ) : (
                  <p class="mt-0.5 text-xs italic text-zinc-600">No tags</p>
                )}
              </div>
            </a>
          );
        })}
      </div>
    )}

    {nextCursor && (
      <div class="mt-8 flex justify-center">
        <a
          href={`/library?${new URLSearchParams({ ...(search ? { q: search } : {}), cursor: nextCursor })}`}
          class="btn-secondary"
        >
          Next page
        </a>
      </div>
    )}

    <div id="no-results" class="hidden rounded-xl border border-dashed border-white/10 bg-white/5 p-12 text-center">
      <svg class="mx-auto h-10 w-10 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <h3 class="mt-4 text-lg font-medium text-white">No assets found</h3>
      <p class="mt-1 text-sm text-zinc-400">Try a different search term.</p>
    </div>
  </div>

  <script>
    const input = document.getElementById('library-search') as HTMLInputElement;
    const grid = document.getElementById('asset-grid');
    const noResults = document.getElementById('no-results')!;

    if (input && grid) {
      input.addEventListener('input', () => {
        const query = input.value.toLowerCase().trim();
        const cards = grid.querySelectorAll('.asset-card') as NodeListOf<HTMLElement>;
        let visible = 0;

        cards.forEach((card) => {
          const matches = !query || (card.dataset.search ?? '').includes(query);
          card.style.display = matches ? '' : 'none';
          if (matches) visible++;
        });

        if (grid) {
          grid.style.display = visible === 0 && query ? 'none' : '';
        }
        if (noResults) {
          noResults.classList.toggle('hidden', !(visible === 0 && query));
        }
      });
    }
  </script>
</BaseLayout>
