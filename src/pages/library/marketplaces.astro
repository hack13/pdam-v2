---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LibraryNav from '../../components/LibraryNav.astro';
import { MarketplaceManager } from '../../components/MarketplaceManager';
import { getSessionFromContext } from '../../lib/session';

const session = await getSessionFromContext(Astro);

if (!session?.user) {
  return Astro.redirect('/login');
}
---

<BaseLayout title="Marketplaces - Library - PDAM" isAuthenticated={true}>
  <div class="app-page">
    <div class="app-header">
      <div>
        <p class="app-kicker">Sources and storefronts</p>
        <h1 class="app-title">Marketplaces</h1>
        <p class="app-description">Keep source links consistent so every asset can be traced back to where it came from.</p>
      </div>
    </div>

    <LibraryNav current="marketplaces" />

    <div class="app-panel-raised p-5 sm:p-6">
      <MarketplaceManager client:visible />
    </div>
  </div>
</BaseLayout>
