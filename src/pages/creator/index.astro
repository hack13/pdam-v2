---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CreatorNav from '../../components/CreatorNav.astro';
import { getCreatorUserFromContext, getLinkedCreator } from '../../lib/creator';
import { getCreatorDashboardStats } from '../../lib/creator-stats';

const user = await getCreatorUserFromContext(Astro);
if (!user) {
  return Astro.redirect('/creator/apply');
}

const linked = await getLinkedCreator(user.id);
if (!linked) {
  return Astro.redirect('/creator/apply');
}

const stats = await getCreatorDashboardStats(user.id);
---

<BaseLayout title="Creator Dashboard - PDAM" isAuthenticated={true}>
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-white">Content Creator</h1>
      <p class="mt-1 text-sm text-zinc-400">
        Track listings, ownership confirmations, and marketplace interest.
      </p>
    </div>

    <CreatorNav current="dashboard" />

    <div class="mb-8 rounded-xl border border-white/10 bg-white/5 p-5">
      <p class="text-sm text-zinc-400">Linked as</p>
      <p class="mt-1 text-lg font-medium text-white">{linked.name}</p>
      <a href="/creator/profile" class="mt-2 inline-block text-sm text-indigo-400 hover:text-indigo-300">
        Manage profile &rarr;
      </a>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <p class="text-sm text-zinc-400">Listed items</p>
        <p class="mt-1 text-3xl font-bold text-white">{stats.listingCount}</p>
        <a href="/creator/listings" class="mt-2 inline-block text-sm text-indigo-400 hover:text-indigo-300">
          Manage listings &rarr;
        </a>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <p class="text-sm text-zinc-400">Ownership confirmations</p>
        <p class="mt-1 text-3xl font-bold text-white">{stats.ownershipConfirmations}</p>
        <p class="mt-2 text-xs text-zinc-500">Buyers who verified a license for your listings</p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <p class="text-sm text-zinc-400">Marketplace clicks</p>
        <p class="mt-1 text-3xl font-bold text-white">{stats.totalMarketplaceClicks}</p>
        <p class="mt-2 text-xs text-zinc-500">Outbound visits to purchase pages</p>
      </div>
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="mb-4 text-lg font-semibold text-white">Clicks by marketplace</h2>
      {stats.marketplaceClicks.length === 0 ? (
        <p class="text-sm text-zinc-500">No marketplace clicks recorded yet.</p>
      ) : (
        <div class="space-y-3">
          {stats.marketplaceClicks.map((row) => (
            <div class="flex items-center justify-between border-b border-white/5 pb-3 last:border-0 last:pb-0">
              <span class="text-sm text-zinc-300">{row.marketplaceName}</span>
              <span class="text-sm font-medium text-white">{row.clicks}</span>
            </div>
          ))}
        </div>
      )}
    </div>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <a
        href="/creator/listings"
        class="rounded-xl border border-white/10 bg-white/5 p-5 transition-colors hover:border-white/20 hover:bg-white/[0.07]"
      >
        <h3 class="font-medium text-white">Manage listings</h3>
        <p class="mt-1 text-sm text-zinc-400">Publish assets tagged with your linked creator.</p>
      </a>
      <a
        href="/creator/webhooks"
        class="rounded-xl border border-white/10 bg-white/5 p-5 transition-colors hover:border-white/20 hover:bg-white/[0.07]"
      >
        <h3 class="font-medium text-white">Verification tooling</h3>
        <p class="mt-1 text-sm text-zinc-400">Connect webhooks so license checks hit your own endpoints.</p>
      </a>
    </div>
  </div>
</BaseLayout>
