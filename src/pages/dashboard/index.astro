---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SignOutButton } from '../../components/SignOutButton';
import { ApiKeyManager } from '../../components/ApiKeyManager';
import { PasskeyManager } from '../../components/PasskeyManager';
import { GoogleAccountManager } from '../../components/GoogleAccountManager';
import { ProfilePicture } from '../../components/ProfilePicture';
import { InviteReferrals } from '../../components/InviteReferrals';
import { getSessionFromContext } from '../../lib/session';
import { db } from '../../db';
import { products, users } from '../../db/schema';
import { count, eq } from 'drizzle-orm';
import { getUserStorage, formatBytes } from '../../lib/storage-accounting';
import { isCreatorUser, getLinkedCreator } from '../../lib/creator';
import { getPendingApplication } from '../../lib/creator-applications';

const session = await getSessionFromContext(Astro);

if (!session?.user) {
  return Astro.redirect('/login');
}

const user = await db.query.users.findFirst({
  where: eq(users.id, session.user.id),
});

if (!user) {
  return Astro.redirect('/login');
}

const isAuthenticated = true;
const isCreator = isCreatorUser(user);
const [{ assetCount }, linkedCreator, pendingApplication, userStorage] = await Promise.all([
  db.select({ assetCount: count() }).from(products).where(eq(products.ownerUserId, user.id)).then(([row]) => row),
  isCreator ? getLinkedCreator(user.id) : Promise.resolve(null),
  getPendingApplication(user.id),
  getUserStorage(user.id),
]);
const totalStorageBytes = userStorage?.logicalBytesUsed ?? 0;
const storageUsed = formatBytes(totalStorageBytes);

const memberSince = new Date(user.createdAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const fallbackAvatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(user.name)}&background=6366f1&color=fff`;
---

<BaseLayout title="Account Dashboard - PDAM" isAuthenticated={isAuthenticated}>
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white">Account Dashboard</h1>
        <p class="mt-1 text-sm text-zinc-400">Manage your account settings and view usage.</p>
      </div>
    </div>

    {!isCreator && !pendingApplication && (
      <div class="mb-8 rounded-xl border border-white/10 bg-white/5 p-5">
        <h2 class="font-medium text-white">Are you a content creator?</h2>
        <p class="mt-1 text-sm text-zinc-400">
          Apply to claim your creator identity. An admin will verify your storefront proof before
          granting gallery listing access.
        </p>
        <a href="/creator/apply" class="btn-primary mt-4 inline-flex">Become a creator</a>
      </div>
    )}

    {pendingApplication && (
      <div class="mb-8 rounded-xl border border-amber-500/20 bg-amber-500/5 p-5">
        <h2 class="font-medium text-white">Creator application pending</h2>
        <p class="mt-1 text-sm text-zinc-400">
          Your request to represent <span class="text-zinc-200">{pendingApplication.requestedCreatorName}</span> is
          waiting for admin review.
        </p>
        <a href="/creator/apply" class="mt-3 inline-block text-sm text-indigo-400 hover:text-indigo-300">
          View application &rarr;
        </a>
      </div>
    )}

    {isCreator && linkedCreator && (
      <div class="mb-8 rounded-xl border border-emerald-500/20 bg-emerald-500/10 p-5">
        <h2 class="font-medium text-white">Verified creator · {linkedCreator.name}</h2>
        <a href="/creator" class="mt-2 inline-block text-sm text-indigo-400 hover:text-indigo-300">
          Open creator dashboard &rarr;
        </a>
      </div>
    )}

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="flex items-center gap-4">
          <ProfilePicture
            client:load
            currentImageUrl={user.image ?? ''}
            fallbackUrl={fallbackAvatarUrl}
          />
          <div class="min-w-0">
            <p class="font-medium text-white">{user.name}</p>
            <p class="mt-1 text-xs text-zinc-500">Member since {memberSince}</p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <p class="text-sm text-zinc-400">Total Assets</p>
        <p class="mt-1 text-3xl font-bold text-white">{assetCount}</p>
        <a href="/library" class="mt-2 inline-block text-sm text-indigo-400 hover:text-indigo-300">View Library &rarr;</a>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <p class="text-sm text-zinc-400">Storage Used</p>
        <p class="mt-1 text-3xl font-bold text-white">{storageUsed}</p>
      </div>
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="mb-4 text-lg font-semibold text-white">Account</h2>
      <div class="space-y-3">
        <div class="flex items-center justify-between border-b border-white/5 pb-3">
          <span class="text-sm text-zinc-400">Name</span>
          <span class="text-sm text-white">{user.name}</span>
        </div>
        <div class="flex items-center justify-between border-b border-white/5 pb-3">
          <span class="text-sm text-zinc-400">Email</span>
          <span class="text-sm text-white">{user.email}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-zinc-400">Session</span>
          <SignOutButton client:load userName={user.name} />
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <PasskeyManager client:visible />
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <InviteReferrals client:visible />
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <GoogleAccountManager client:visible />
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <ApiKeyManager client:visible />
    </div>

  </div>
</BaseLayout>
