---
interface Props {
  current: 'dashboard' | 'profile' | 'listings' | 'webhooks';
}

const { current } = Astro.props;
const links = [
  { key: 'dashboard', label: 'Overview', href: '/creator' },
  { key: 'profile', label: 'Creator profile', href: '/creator/profile' },
  { key: 'listings', label: 'Listings', href: '/creator/listings' },
  { key: 'webhooks', label: 'Verification', href: '/creator/webhooks' },
] as const;
---

<nav aria-label="Creator studio navigation" class="app-nav">
  {links.map((link) => (
    <a href={link.href} class="app-nav-link" aria-current={current === link.key ? 'page' : undefined}>
      {link.label}
    </a>
  ))}
</nav>
