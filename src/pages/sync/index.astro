---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SyncNav from '../../components/SyncNav.astro';
import { getSessionFromContext } from '../../lib/session';
import { db } from '../../db';
import { eq } from 'drizzle-orm';
import { syncRuns, userAssetFiles, userStorageConnections } from '../../db/schema';
import { formatBytes } from '../../lib/storage-accounting';
import { HtmlArchiveExport } from '../../components/HtmlArchiveExport';

const session = await getSessionFromContext(Astro);
if (!session?.user) return Astro.redirect('/login');

const userId = session.user.id;
const [connections, backedUpFiles] = await Promise.all([
  db.query.userStorageConnections.findMany({ where: eq(userStorageConnections.userId, userId) }),
  db.query.userAssetFiles.findMany({ where: eq(userAssetFiles.userId, userId), columns: { logicalSizeBytes: true, isBackedUp: true } }),
]);
const recentRuns = await db.query.syncRuns.findMany({
  where: eq(syncRuns.userId, userId),
  orderBy: (table, { desc }) => [desc(table.createdAt)],
  limit: 5,
});
const backedUpBytes = backedUpFiles.filter((file) => file.isBackedUp).reduce((total, file) => total + Number(file.logicalSizeBytes), 0);
const lastBackup = connections.map((connection) => connection.lastSuccessfulSyncAt).filter(Boolean).sort((a, b) => b!.getTime() - a!.getTime())[0] ?? null;
const failedRuns = recentRuns.filter((run) => run.status === 'failed' || run.status === 'partial').length;
---

<BaseLayout title="Sync Overview - TailCache" isAuthenticated={true}>
  <div class="app-page">
    <div class="app-header">
      <div>
        <p class="app-kicker">Backup control room</p>
        <h1 class="app-title">Sync</h1>
        <p class="app-description">Choose where copies live, see what happened, and keep a local copy close at hand.</p>
      </div>
    </div>
    <SyncNav current="dashboard" />

    <div class="mb-8"><HtmlArchiveExport client:load /></div>

    <div class="mb-8 grid gap-4 md:grid-cols-3">
      <div class="app-stat border-indigo-400/20 p-5">
        <p class="app-kicker !text-zinc-500">Last successful backup</p>
        <p class="mt-3 font-display text-2xl font-semibold text-white">{lastBackup ? lastBackup.toLocaleString() : 'Not yet'}</p>
        <p class="mt-2 text-xs text-zinc-500">Across all connected destinations</p>
      </div>
      <div class="app-stat p-5">
        <p class="app-kicker !text-zinc-500">Backed-up storage</p>
        <p class="mt-3 font-display text-2xl font-semibold text-white">{formatBytes(backedUpBytes)}</p>
        <p class="mt-2 text-xs text-zinc-500">{backedUpFiles.filter((file) => file.isBackedUp).length} file(s) acknowledged</p>
      </div>
      <div class:list={["app-stat p-5", failedRuns ? "border-amber-400/20" : "border-cyan-400/20" ]}>
        <p class="app-kicker !text-zinc-500">Destination health</p>
        <p class="mt-3 font-display text-2xl font-semibold text-white">{connections.filter((connection) => connection.enabled).length} active</p>
        <p class="mt-2 text-xs text-zinc-500">{failedRuns ? `${failedRuns} recent run(s) need attention` : 'No recent failures'}</p>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <section class="app-panel-raised p-6">
        <div class="flex items-start justify-between gap-4"><div><h2 class="text-lg font-semibold text-white">Your backup map</h2><p class="mt-1 text-sm text-zinc-400">Append-only copies stay in destinations you control.</p></div><a href="/sync/destinations" class="text-sm text-indigo-300 hover:text-indigo-200">Manage destinations →</a></div>
        {connections.length === 0 ? <div class="mt-8 rounded-xl border border-dashed border-white/15 p-6 text-center"><p class="text-sm text-zinc-300">No backup destinations connected.</p><a href="/sync/destinations" class="mt-3 inline-block text-sm text-indigo-300">Connect storage →</a></div> : <div class="mt-6 space-y-3">{connections.map((connection) => <div class="flex items-center justify-between rounded-xl border border-white/10 bg-black/10 px-4 py-3"><div><p class="text-sm font-medium text-white">{connection.providerName}</p><p class="mt-1 text-xs text-zinc-500">{connection.providerType} · {connection.lastSuccessfulSyncAt ? `Last backup ${connection.lastSuccessfulSyncAt.toLocaleString()}` : 'Never backed up'}</p></div><span class:list={["rounded-full px-2 py-1 text-xs", connection.lastError ? "bg-amber-400/10 text-amber-300" : "bg-emerald-400/10 text-emerald-300"]}>{connection.lastError ? 'Needs attention' : 'Ready'}</span></div>)}</div>}
      </section>
      <section class="app-panel p-6"><h2 class="text-lg font-semibold text-white">Recent activity</h2><div class="mt-5 space-y-3">{recentRuns.length === 0 ? <p class="text-sm text-zinc-500">Sync activity will appear here after your first run.</p> : recentRuns.map((run) => <div class="flex items-center justify-between border-b border-white/5 pb-3"><div><p class="text-sm text-zinc-300">{run.status}</p><p class="mt-1 text-xs text-zinc-500">{run.createdAt.toLocaleString()}</p></div><span class="text-xs text-zinc-500">{run.filesUploaded} uploaded</span></div>)}<a href="/sync/status" class="inline-block pt-2 text-sm text-indigo-300 hover:text-indigo-200">View sync activity →</a></div></section>
    </div>
  </div>
</BaseLayout>
