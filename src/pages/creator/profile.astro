---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CreatorNav from '../../components/CreatorNav.astro';
import { CreatorOnboardingForm } from '../../components/CreatorOnboardingForm';
import { CreatorProfileEditor } from '../../components/CreatorProfileEditor';
import { getCreatorUserFromContext, getLinkedCreator } from '../../lib/creator';
import {
  getLatestApplication,
  getPendingApplication,
} from '../../lib/creator-applications';

const user = await getCreatorUserFromContext(Astro);
if (!user) {
  return Astro.redirect('/creator/apply');
}

const linked = await getLinkedCreator(user.id);
const pending = await getPendingApplication(user.id);
const latest = await getLatestApplication(user.id);

function serializeApp(row: NonNullable<typeof pending>) {
  return {
    id: row.id,
    creatorId: row.creatorId,
    requestedCreatorName: row.requestedCreatorName,
    proofUrls: row.proofUrls ?? [],
    applicantNote: row.applicantNote,
    status: row.status,
    adminNote: row.adminNote,
    reviewedAt: row.reviewedAt?.toISOString() ?? null,
    createdAt: row.createdAt.toISOString(),
  };
}
---

<BaseLayout title="Creator Profile - TailCache" isAuthenticated={true}>
  <div class="app-page">
    <div class="app-header">
      <div>
      <p class="app-kicker">Creator studio</p>
      <h1 class="app-title">Creator profile</h1>
      <p class="app-description">Shape the public page that brings your work and storefronts together.</p>
      </div>
    </div>

    <CreatorNav current="profile" />

    <CreatorOnboardingForm
      client:load
      initialIsCreator={true}
      initialLinkedCreator={linked ? { id: linked.id, name: linked.name, slug: linked.slug } : null}
      initialPending={pending ? serializeApp(pending) : null}
      initialLatest={latest ? serializeApp(latest) : null}
    />

    {linked && (
      <div class="mt-6">
        <CreatorProfileEditor
          client:load
          creator={{
            id: linked.id,
            name: linked.name,
            slug: linked.slug,
            bio: linked.bio,
            avatarUrl: linked.avatarUrl,
            profileImageUrl: linked.profileImageUrl,
            headerImageUrl: linked.headerImageUrl,
          }}
        />
      </div>
    )}
  </div>
</BaseLayout>
