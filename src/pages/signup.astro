---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SignUpForm } from '../components/SignUpForm';
import { getSessionFromContext } from '../lib/session';

const session = await getSessionFromContext(Astro);
const isAuthenticated = !!session?.user;

if (isAuthenticated) {
  return Astro.redirect('/dashboard');
}
---

<BaseLayout title="Create Account - PDAM" isAuthenticated={isAuthenticated}>
  <div class="flex min-h-[calc(100vh-4rem)] items-center justify-center px-6 py-16">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-xl" style="background: linear-gradient(135deg, #6366f1, #8b5cf6);">
          <svg class="h-7 w-7 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
            <line x1="12" y1="22.08" x2="12" y2="12"/>
          </svg>
        </div>
        <h1 class="text-3xl font-bold text-white">Create your account</h1>
        <p class="mt-2 text-sm text-zinc-400">Join PDAM and start organizing your VR assets</p>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm">
        <SignUpForm client:load />
      </div>
    </div>
  </div>
</BaseLayout>
