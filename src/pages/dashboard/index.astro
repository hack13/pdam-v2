---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SignOutButton } from '../../components/SignOutButton';
import { MarketplaceManager } from '../../components/MarketplaceManager';
import { ApiKeyManager } from '../../components/ApiKeyManager';
import { ProfilePicture } from '../../components/ProfilePicture';
import { getSessionFromContext } from '../../lib/session';
import { db } from '../../db';
import { products, users } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { getUserStorage, formatBytes } from '../../lib/storage-accounting';

const session = await getSessionFromContext(Astro);

if (!session?.user) {
  return Astro.redirect('/login');
}

const user = await db.query.users.findFirst({
  where: eq(users.id, session.user.id),
});

if (!user) {
  return Astro.redirect('/login');
}

const isAuthenticated = true;

const assetCount = (await db.query.products.findMany({
  where: eq(products.ownerUserId, user.id),
  columns: { id: true },
})).length;

const userStorage = await getUserStorage(user.id);
const totalStorageBytes = userStorage?.logicalBytesUsed ?? 0;
const storageUsed = formatBytes(totalStorageBytes);

const memberSince = new Date(user.createdAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const fallbackAvatarUrl = `https://ui-avatars.com/api/?name=${encodeURIComponent(user.name)}&background=6366f1&color=fff`;
---

<BaseLayout title="Account Dashboard - PDAM" isAuthenticated={isAuthenticated}>
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-white">Account Dashboard</h1>
        <p class="mt-1 text-sm text-zinc-400">Manage your account settings and view usage.</p>
      </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <div class="flex items-center gap-4">
          <ProfilePicture
            client:load
            currentImageUrl={user.image ?? ''}
            fallbackUrl={fallbackAvatarUrl}
          />
          <div class="min-w-0">
            <p class="font-medium text-white">{user.name}</p>
            <p class="mt-1 text-xs text-zinc-500">Member since {memberSince}</p>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <p class="text-sm text-zinc-400">Total Assets</p>
        <p class="mt-1 text-3xl font-bold text-white">{assetCount}</p>
        <a href="/library" class="mt-2 inline-block text-sm text-indigo-400 hover:text-indigo-300">View Library &rarr;</a>
      </div>

      <div class="rounded-xl border border-white/10 bg-white/5 p-6">
        <p class="text-sm text-zinc-400">Storage Used</p>
        <p class="mt-1 text-3xl font-bold text-white">{storageUsed}</p>
      </div>
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <h2 class="mb-4 text-lg font-semibold text-white">Account</h2>
      <div class="space-y-3">
        <div class="flex items-center justify-between border-b border-white/5 pb-3">
          <span class="text-sm text-zinc-400">Name</span>
          <span class="text-sm text-white">{user.name}</span>
        </div>
        <div class="flex items-center justify-between border-b border-white/5 pb-3">
          <span class="text-sm text-zinc-400">Email</span>
          <span class="text-sm text-white">{user.email}</span>
        </div>
        <div class="flex items-center justify-between">
          <span class="text-sm text-zinc-400">Session</span>
          <SignOutButton client:load userName={user.name} />
        </div>
      </div>
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <ApiKeyManager client:load />
    </div>

    <div class="mt-8 rounded-xl border border-white/10 bg-white/5 p-6">
      <MarketplaceManager client:load />
    </div>
  </div>
</BaseLayout>
