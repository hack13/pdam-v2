---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { CreatorOnboardingForm } from '../../components/CreatorOnboardingForm';
import { getSessionFromContext } from '../../lib/session';
import { db } from '../../db';
import { users } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { isCreatorUser, getLinkedCreator } from '../../lib/creator';
import {
  getLatestApplication,
  getPendingApplication,
} from '../../lib/creator-applications';

const session = await getSessionFromContext(Astro);
if (!session?.user) {
  return Astro.redirect('/login?redirect=/creator/apply');
}

const user = await db.query.users.findFirst({
  where: eq(users.id, session.user.id),
});
if (!user) {
  return Astro.redirect('/login');
}

const linked = await getLinkedCreator(user.id);
const pending = await getPendingApplication(user.id);
const latest = await getLatestApplication(user.id);

// Approved creators with a link go to the creator dashboard
if (isCreatorUser(user) && linked && !pending) {
  return Astro.redirect('/creator');
}

function serializeApp(row: NonNullable<typeof pending>) {
  return {
    id: row.id,
    creatorId: row.creatorId,
    requestedCreatorName: row.requestedCreatorName,
    proofUrls: row.proofUrls ?? [],
    applicantNote: row.applicantNote,
    status: row.status,
    adminNote: row.adminNote,
    reviewedAt: row.reviewedAt?.toISOString() ?? null,
    createdAt: row.createdAt.toISOString(),
  };
}
---

<BaseLayout title="Become a Creator - PDAM" isAuthenticated={true}>
  <div class="mx-auto max-w-3xl px-6 py-12">
    <div class="mb-8">
      <a href="/dashboard" class="mb-4 inline-flex text-sm text-zinc-400 hover:text-white">
        &larr; Back to account
      </a>
      <h1 class="text-3xl font-bold text-white">Creator onboarding</h1>
      <p class="mt-1 text-sm text-zinc-400">
        Apply to represent a creator identity. Admins verify proof before granting access — this
        helps stop impersonation.
      </p>
    </div>

    <CreatorOnboardingForm
      client:load
      initialIsCreator={isCreatorUser(user)}
      initialLinkedCreator={linked ? { id: linked.id, name: linked.name, slug: linked.slug } : null}
      initialPending={pending ? serializeApp(pending) : null}
      initialLatest={latest ? serializeApp(latest) : null}
    />
  </div>
</BaseLayout>
